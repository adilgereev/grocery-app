{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "app/_layout.tsx",
    "app/**/*.tsx"
  ],
  "project": [
    "**/*.{ts,tsx}"
  ],
  "ignoreDependencies": [
    "expo-router/entry",
    "babel-plugin-transform-import-meta"
  ],
  "ignore": [
    "node_modules/**",
    ".expo/**",
    "dist/**",
    "scripts/**",
    "**/*.ios.tsx",
    "**/*.android.tsx",
    "**/*.native.tsx",
    "business-admin/**",
    "supabase/functions/**",
    "types/supabase.ts"
  ],
  "rules": {
    "files": "warn",
    "dependencies": "error",
    "unlisted": "error",
    "exports": "warn",
    "types": "warn"
  }
}